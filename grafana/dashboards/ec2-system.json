{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Load Average (1m, 5m, 15m)",
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "Load 1m",
          "refId": "A"
        },
        {
          "expr": "node_load5",
          "legendFormat": "Load 5m",
          "refId": "B"
        },
        {
          "expr": "node_load15",
          "legendFormat": "Load 15m",
          "refId": "C"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (Used vs Total)",
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Memory Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Memory Total",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Network Traffic (Bytes In/Out)",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total[2m])",
          "legendFormat": "Bytes In ({{device}})",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total[2m])",
          "legendFormat": "Bytes Out ({{device}})",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Disk Read/Write (Bytes/sec)",
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[2m])",
          "legendFormat": "Read ({{device}})",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[2m])",
          "legendFormat": "Write ({{device}})",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Filesystem Usage (%)",
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{fstype!=\"tmpfs\",fstype!=\"overlay\"} - node_filesystem_avail_bytes{fstype!=\"tmpfs\",fstype!=\"overlay\"}) / node_filesystem_size_bytes{fstype!=\"tmpfs\",fstype!=\"overlay\"} * 100",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["node-exporter", "system", "ec2"],
  "timezone": "",
  "title": "EC2 System Metrics (Node Exporter)",
  "version": 1,
  "weekStart": ""
}
