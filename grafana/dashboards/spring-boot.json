{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Application Uptime (seconds)",
      "datasource": null,
      "targets": [
        {
          "expr": "process_uptime_seconds",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests per Second",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "Heap Used",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Max",
      "targets": [
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "Heap Max",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "JVM Live Threads",
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "Live Threads",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "GC Pause Time",
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[5m])",
          "legendFormat": "GC Pause",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "HikariCP Active Connections",
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "HikariCP Idle Connections",
      "targets": [
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "Idle",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 6 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["spring", "prometheus", "micrometer"],
  "timezone": "",
  "title": "Spring Boot Application Dashboard",
  "version": 1,
  "weekStart": ""
}
